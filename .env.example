PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/majid

# Device IMEI check API credentials
DHRU_BASE_URL=https://sickw.com
IMEI_PROVIDER=sickw
DHRU_USERNAME=replace-me
DHRU_API_KEY=replace-me
DHRU_TIMEOUT_MS=60000
SICKW_RESPONSE_FORMAT=json
IMEI_ENABLE_SERVICE_FALLBACK=false

BCRYPT_SALT_ROUNDS=10
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

EMAIL_ADDRESS=you@example.com
EMAIL_PASSWORD=replace-me

CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

STRIPE_SECRET_KEY=replace-me
STRIPE_PUBLIC_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me

EAN_SEARCH_TOKEN=replace-me
OPENAI_API_KEY=replace-me
FRONTEND_URL=https://yourdomain.com
LOW_STOCK_ENABLE_EMAIL=true
LOW_STOCK_EMAIL_WORKERS=4
LOW_STOCK_EMAIL_BATCH_SIZE=5
