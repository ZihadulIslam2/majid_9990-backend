{
      "info": {
            "name": "Invoice Module APIs",
            "_postman_id": "b8f0b1d9-6a3b-4c1d-9f6b-1a2e3d4c5f6a",
            "description": "Postman collection for the Invoice module endpoints.\n\nBase route: /api/v1/invoices\n\nCreate/Update use multipart/form-data because the invoice file is uploaded with Multer.\n\nField details:\n- shopkeeperId: required ObjectId string referencing a User document with shopkeeper role\n- type: required text field describing the invoice type\n- invoice: required file upload for create, optional file upload for update\n- customerInfo: optional ObjectId string referencing a Customer document, accepted on update\n- itemsIds: optional Inventory ObjectId string array, accepted on update\n\nSet environment variables baseUrl and token before using.",
            "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
      },
      "item": [
            {
                  "name": "Create Invoice",
                  "request": {
                        "description": "Creates a new invoice record and uploads the invoice file to Cloudinary.\n\nRequired fields:\n- shopkeeperId: MongoDB ObjectId of an existing User\n- type: invoice category or identifier\n- invoice: PDF or raw file upload\n\nThe endpoint does not persist customerInfo or itemsIds on create; only shopkeeperId, type, and invoice are saved.",
                        "auth": {
                              "type": "bearer",
                              "bearer": [
                                    {
                                          "key": "token",
                                          "value": "{{token}}",
                                          "type": "string"
                                    }
                              ]
                        },
                        "method": "POST",
                        "header": [],
                        "body": {
                              "mode": "formdata",
                              "formdata": [
                                    {
                                          "key": "shopkeeperId",
                                          "value": "",
                                          "type": "text"
                                    },
                                    {
                                          "key": "type",
                                          "value": "",
                                          "type": "text"
                                    },
                                    {
                                          "key": "invoice",
                                          "type": "file",
                                          "src": ""
                                    }
                              ]
                        },
                        "url": {
                              "raw": "{{baseUrl}}/api/v1/invoices/create",
                              "host": ["{{baseUrl}}"],
                              "path": ["api", "v1", "invoices", "create"]
                        }
                  }
            },
            {
                  "name": "Get All Invoices",
                  "request": {
                        "description": "Returns all invoices sorted by newest first. Populates shopkeeperId, customerInfo, and itemsIds fields in the response.",
                        "auth": {
                              "type": "bearer",
                              "bearer": [
                                    {
                                          "key": "token",
                                          "value": "{{token}}",
                                          "type": "string"
                                    }
                              ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                              "raw": "{{baseUrl}}/api/v1/invoices/all",
                              "host": ["{{baseUrl}}"],
                              "path": ["api", "v1", "invoices", "all"]
                        }
                  }
            },
            {
                  "name": "Get Invoices By Shopkeeper",
                  "request": {
                        "description": "Returns invoices filtered by a shopkeeper ObjectId. The path parameter must be a valid MongoDB ObjectId.",
                        "auth": {
                              "type": "bearer",
                              "bearer": [
                                    {
                                          "key": "token",
                                          "value": "{{token}}",
                                          "type": "string"
                                    }
                              ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                              "raw": "{{baseUrl}}/api/v1/invoices/shopkeeper/:shopkeeperId",
                              "host": ["{{baseUrl}}"],
                              "path": ["api", "v1", "invoices", "shopkeeper", ":shopkeeperId"],
                              "variable": [
                                    {
                                          "key": "shopkeeperId",
                                          "value": ""
                                    }
                              ]
                        }
                  }
            },
            {
                  "name": "Update Invoice",
                  "request": {
                        "description": "Updates an existing invoice. All fields are optional.\n\nSupported update fields:\n- shopkeeperId: new shopkeeper ObjectId\n- type: updated invoice type\n- customerInfo: Customer ObjectId\n- itemsIds: one or more Inventory ObjectIds\n- invoice: new file upload; when sent, the old Cloudinary file is removed first\n\nFor itemsIds, you can send repeated form-data rows with the same key or a comma-separated string that your client splits before sending.",
                        "auth": {
                              "type": "bearer",
                              "bearer": [
                                    {
                                          "key": "token",
                                          "value": "{{token}}",
                                          "type": "string"
                                    }
                              ]
                        },
                        "method": "PUT",
                        "header": [],
                        "body": {
                              "mode": "formdata",
                              "formdata": [
                                    {
                                          "key": "shopkeeperId",
                                          "value": "",
                                          "type": "text"
                                    },
                                    {
                                          "key": "type",
                                          "value": "",
                                          "type": "text"
                                    },
                                    {
                                          "key": "customerInfo",
                                          "value": "",
                                          "type": "text"
                                    },
                                    {
                                          "key": "itemsIds",
                                          "value": "",
                                          "type": "text"
                                    },
                                    {
                                          "key": "itemsIds",
                                          "value": "",
                                          "type": "text"
                                    },
                                    {
                                          "key": "invoice",
                                          "type": "file",
                                          "src": ""
                                    }
                              ]
                        },
                        "url": {
                              "raw": "{{baseUrl}}/api/v1/invoices/:id",
                              "host": ["{{baseUrl}}"],
                              "path": ["api", "v1", "invoices", ":id"],
                              "variable": [
                                    {
                                          "key": "id",
                                          "value": ""
                                    }
                              ]
                        }
                  }
            },
            {
                  "name": "Delete Invoice",
                  "request": {
                        "description": "Deletes an invoice by id and removes the uploaded invoice file from Cloudinary.",
                        "auth": {
                              "type": "bearer",
                              "bearer": [
                                    {
                                          "key": "token",
                                          "value": "{{token}}",
                                          "type": "string"
                                    }
                              ]
                        },
                        "method": "DELETE",
                        "header": [],
                        "url": {
                              "raw": "{{baseUrl}}/api/v1/invoices/:id",
                              "host": ["{{baseUrl}}"],
                              "path": ["api", "v1", "invoices", ":id"],
                              "variable": [
                                    {
                                          "key": "id",
                                          "value": ""
                                    }
                              ]
                        }
                  }
            }
      ],
      "variable": [
            {
                  "key": "baseUrl",
                  "value": "http://localhost:5000"
            },
            {
                  "key": "token",
                  "value": ""
            }
      ]
}
