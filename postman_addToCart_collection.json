{
      "info": {
            "name": "Add To Cart API Collection",
            "description": "Postman collection for testing Add To Cart APIs",
            "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
      },
      "variable": [
            {
                  "key": "baseUrl",
                  "value": "http://localhost:5000/api/v1"
            },
            {
                  "key": "token",
                  "value": "paste_jwt_token_here"
            },
            {
                  "key": "shopkeeperId",
                  "value": "665f0a5a9f8b123456789012"
            },
            {
                  "key": "itemId",
                  "value": "665f0b6b9f8b123456789013"
            },
            {
                  "key": "cartId",
                  "value": "665f0c7c9f8b123456789014"
            }
      ],
      "item": [
            {
                  "name": "Create Add To Cart",
                  "request": {
                        "method": "POST",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "{{token}}",
                                    "type": "text"
                              },
                              {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                              }
                        ],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n  \"shopkeeperId\": \"{{shopkeeperId}}\",\n  \"itemId\": \"{{itemId}}\",\n  \"quantity\": 2\n}"
                        },
                        "url": {
                              "raw": "{{baseUrl}}/add-to-cart/create",
                              "host": ["{{baseUrl}}"],
                              "path": ["add-to-cart", "create"]
                        }
                  },
                  "response": []
            },
            {
                  "name": "Get Add To Cart By Shopkeeper Id",
                  "request": {
                        "method": "GET",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "{{token}}",
                                    "type": "text"
                              }
                        ],
                        "url": {
                              "raw": "{{baseUrl}}/add-to-cart/shopkeeper/{{shopkeeperId}}",
                              "host": ["{{baseUrl}}"],
                              "path": ["add-to-cart", "shopkeeper", "{{shopkeeperId}}"]
                        }
                  },
                  "response": []
            },
            {
                  "name": "Update Add To Cart",
                  "request": {
                        "method": "PUT",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "{{token}}",
                                    "type": "text"
                              },
                              {
                                    "key": "Content-Type",
                                    "value": "application/json",
                                    "type": "text"
                              }
                        ],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n  \"quantity\": 3\n}"
                        },
                        "url": {
                              "raw": "{{baseUrl}}/add-to-cart/update/{{cartId}}",
                              "host": ["{{baseUrl}}"],
                              "path": ["add-to-cart", "update", "{{cartId}}"]
                        }
                  },
                  "response": []
            },
            {
                  "name": "Delete Add To Cart",
                  "request": {
                        "method": "DELETE",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "{{token}}",
                                    "type": "text"
                              }
                        ],
                        "url": {
                              "raw": "{{baseUrl}}/add-to-cart/delete/{{cartId}}",
                              "host": ["{{baseUrl}}"],
                              "path": ["add-to-cart", "delete", "{{cartId}}"]
                        }
                  },
                  "response": []
            },
            {
                  "name": "Delete All Add To Cart By Shopkeeper Id",
                  "request": {
                        "method": "DELETE",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "{{token}}",
                                    "type": "text"
                              }
                        ],
                        "url": {
                              "raw": "{{baseUrl}}/add-to-cart/delete-all/shopkeeper/{{shopkeeperId}}",
                              "host": ["{{baseUrl}}"],
                              "path": ["add-to-cart", "delete-all", "shopkeeper", "{{shopkeeperId}}"]
                        }
                  },
                  "response": []
            }
      ]
}
