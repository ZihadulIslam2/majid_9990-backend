              "raw": "{{baseUrl}}/inventory?type=inventory&status=inventory",
              "host": ["{{baseUrl}}"],
              "path": ["inventory"]
            }
          }
        },
        {
          "name": "Get My Inventory",
          "description": "Returns inventory items for the authenticated user. If user is staff, returns the shopkeeper's inventory.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/inventory/my-inventory",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "my-inventory"]
            }
          }
        },
        {
          "name": "Get Inventory by User ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/inventory/user/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "user", ":userId"],
              "variable": [
                { "key": "userId", "value": "{{shopkeeperId}}" }
              ]
            }
          }
        },
