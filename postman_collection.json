{
  "info": {
    "name": "Majid 9990 Backend API - Staff Role",
    "description": "Complete Postman collection with all existing endpoints + new Staff role feature.\n\nBase URL: http://localhost:5000/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "shopkeeperId",
      "value": ""
    },
    {
      "key": "staffToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set('token', jsonData.data.accessToken);",
                  "    if (jsonData.data.user && jsonData.data.user.role === 'staff' && jsonData.data.user.shopkeeperId) {",
                  "        pm.collectionVariables.set('shopkeeperId', jsonData.data.user.shopkeeperId);",
                  "    } else if (jsonData.data.user && jsonData.data.user.id) {",
                  "        pm.collectionVariables.set('shopkeeperId', jsonData.data.user.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"shopkeeper@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token-here\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh-token"]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            }
          }
        },
        {
          "name": "Verify OTP (Forgot Password)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"newPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"oldPassword123\",\n  \"newPassword\": \"newPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "change-password"]
            }
          }
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Register User (Customer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1234567890\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/register",
              "host": ["{{baseUrl}}"],
              "path": ["user", "register"]
            }
          }
        },
        {
          "name": "Register Shopkeeper",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Shop\",\n  \"lastName\": \"Keeper\",\n  \"email\": \"shopkeeper@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1234567890\",\n  \"role\": \"shopkeeper\",\n  \"shopName\": \"My Electronics Shop\",\n  \"shopAddress\": \"123 Main Street, City\",\n  \"whatsappNumber\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/register",
              "host": ["{{baseUrl}}"],
              "path": ["user", "register"]
            }
          }
        },
        {
          "name": "Verify Email (OTP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/verify-email",
              "host": ["{{baseUrl}}"],
              "path": ["user", "verify-email"]
            }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["user", "resend-otp"]
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/my-profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "my-profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"phone\": \"+9876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/update-profile",
              "host": ["{{baseUrl}}"],
              "path": ["user", "update-profile"]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user/all-users",
              "host": ["{{baseUrl}}"],
              "path": ["user", "all-users"]
            }
          }
        },
        {
          "name": "Get All Shopkeepers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/user/shopkeeper?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["user", "shopkeeper"]
            }
          }
        },
        {
          "name": "Get Admin ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/admin_id",
              "host": ["{{baseUrl}}"],
              "path": ["user", "admin_id"]
            }
          }
        },
        {
          "name": "Get Balance History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/balance-history",
              "host": ["{{baseUrl}}"],
              "path": ["user", "balance-history"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/delete-user/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["user", "delete-user", ":userId"],
              "variable": [
                { "key": "userId", "value": "USER_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "STAFF: Create Staff",
          "description": "Creates a staff user under a shopkeeper. Only admins or shopkeepers can create staff. Staff is auto-verified (no email needed).",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Staff\",\n  \"lastName\": \"Member\",\n  \"email\": \"staff@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1234567890\",\n  \"shopkeeperId\": \"{{shopkeeperId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/create-staff",
              "host": ["{{baseUrl}}"],
              "path": ["user", "create-staff"]
            }
          }
        },
        {
          "name": "STAFF: Login as Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set('staffToken', jsonData.data.accessToken);",
                  "    if (jsonData.data.user && jsonData.data.user.shopkeeperId) {",
                  "        pm.collectionVariables.set('shopkeeperId', jsonData.data.user.shopkeeperId);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"staff@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "STAFF: Get Staff List by Shopkeeper",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/staff/:shopkeeperId",
              "host": ["{{baseUrl}}"],
              "path": ["user", "staff", ":shopkeeperId"],
              "variable": [
                { "key": "shopkeeperId", "value": "{{shopkeeperId}}" }
              ]
            }
          }
        },
        {
          "name": "STAFF: Get My Shopkeeper Data",
          "description": "For staff users only. Returns the shopkeeper's profile that this staff belongs to.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staffToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/my-shopkeeper-data",
              "host": ["{{baseUrl}}"],
              "path": ["user", "my-shopkeeper-data"]
            }
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Create Inventory",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "itemName", "value": "iPhone 13", "type": "text" },
                { "key": "imeiNumber", "value": "356789012345678", "type": "text" },
                { "key": "brand", "value": "Apple", "type": "text" },
                { "key": "modelNumber", "value": "A2633", "type": "text" },
                { "key": "purchasePrice", "value": "500", "type": "text" },
                { "key": "expectedPrice", "value": "750", "type": "text" },
                { "key": "quantity", "value": "1", "type": "text" },
                { "key": "image", "type": "file" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/create",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "create"]
            }
          }
        },
        {
          "name": "Create Inventory from Barcode",
          "request": {
            "method": "POST",
            "header": [
