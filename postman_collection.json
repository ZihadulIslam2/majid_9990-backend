              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{shopkeeperId}}\",\n  \"barcodes\": [\n    { \"code\": \"8901234567890\", \"imeiNumber\": \"356789012345680\", \"purchasePrice\": 450 },\n    { \"code\": \"8901234567891\", \"imeiNumber\": \"356789012345681\", \"purchasePrice\": 500 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/create-from-barcode/bulk",
