          "name": "Update Inventory",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "itemName", "value": "Updated iPhone 13", "type": "text" },
                { "key": "expectedPrice", "value": "800", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/:id",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", ":id"],
              "variable": [
                { "key": "id", "value": "INVENTORY_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Delete Inventory",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/inventory/:id",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", ":id"],
              "variable": [
                { "key": "id", "value": "INVENTORY_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Get Sold Inventory",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/inventory/sold-items",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "sold-items"]
            }
          }
        },
        {
          "name": "Get Inventory by Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/inventory/status/:status",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "status", ":status"],
              "variable": [
                { "key": "status", "value": "due" }
              ]
            }
          }
        },
        {
          "name": "Import CSV",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/import-csv",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "import-csv"]
            }
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "Create Invoice",
          "description": "If user is staff, shopkeeperId is auto-set to their associated shopkeeper.",
          "request": {
            "method": "POST",
            "header": [
