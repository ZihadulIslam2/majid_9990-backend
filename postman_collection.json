                { "key": "dueAmount", "value": "0", "type": "text" },
                { "key": "paymentMethod", "value": "cash", "type": "text" },
                { "key": "customerInfo", "value": "CUSTOMER_ID", "type": "text" },
                { "key": "invoice", "type": "file" }
