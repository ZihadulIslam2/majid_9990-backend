              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"8901234567890\",\n  \"userId\": \"{{shopkeeperId}}\",\n  \"imeiNumber\": \"356789012345679\",\n  \"purchasePrice\": 450,\n  \"currentState\": \"new\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/create-from-barcode",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "create-from-barcode"]
